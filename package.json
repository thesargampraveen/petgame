{
  "name": "MyPet",
  "version": "1.0.0",
  "description": "A cute virtual pet game similar to Tamagotchi",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
